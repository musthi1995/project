// GrooveScript to trigger server-side script execution

// Define server API details
const serverUrl = 'https://your-server-api-endpoint'; // Replace with your server's API endpoint
const apiKey = 'your_api_key'; // Replace with your API key or token

// Function to trigger the server-side script
function triggerScript() {
    const url = `${serverUrl}/execute-script`;
    const options = {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${apiKey}`,
        },
        body: JSON.stringify({
            scriptName: 'install_apache.sh' // The script you want to execute
        }),
    };

    fetch(url, options)
        .then(response => response.json())
        .then(data => {
            console.log('Script triggered successfully:', data);
        })
        .catch(error => {
            console.error('Error triggering script:', error);
        });
}

// Call the function to trigger the script
triggerScript();

